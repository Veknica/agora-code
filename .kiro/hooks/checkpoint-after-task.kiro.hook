{
  "version": "1.0.0",
  "enabled": true,
  "name": "checkpoint after task",
  "description": "Save progress after each spec task completes",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "runCommand",
    "command": "/Library/Frameworks/Python.framework/Versions/3.10/bin/agora-code checkpoint --quiet 2>/dev/null || true",
    "timeout": 10
  }
}